<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050510"
    tools:context=".fragments.WelcomeFragment">

    <!-- Decorative Glows -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:background="@drawable/neon_glow_card"
        android:alpha="0.2"
        android:layout_marginTop="-200dp"
        android:layout_marginStart="-200dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/image_illust"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:src="@android:drawable/ic_menu_agenda"
        android:alpha="0.8"
        app:layout_constraintHeight_percent="0.4"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="64dp"
        app:tint="@color/metricValue" />

    <TextView
        android:id="@+id/text_title"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/poppins_bold"
        android:gravity="center"
        android:text="Unlock Your Career Potential"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/image_illust" />

    <TextView
        android:id="@+id/text_subtitle"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/poppins_regular"
        android:gravity="center"
        android:text="Optimize your resume with AI and land your dream job with ease."
        android:textColor="@color/metricLabel"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_title" />

    <!-- Bottom Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_get_started"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:backgroundTint="@color/metricValue"
            android:fontFamily="@font/poppins_bold"
            android:text="GET STARTED"
            android:textColor="#050510"
            app:cornerRadius="16dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
