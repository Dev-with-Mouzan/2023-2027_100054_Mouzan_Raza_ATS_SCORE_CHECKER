<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050510"
    tools:context=".fragments.RewriteSuggestionsFragment">

    <!-- Header -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent">
        
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/header_logo"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/college_logo"
                android:background="@android:color/white"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle"
                android:scaleType="centerCrop"
                android:padding="2dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/button_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_revert"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/header_logo"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="AI Rewrite Suggestions"
                android:textColor="@color/white"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
                
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="REWRITE YOUR EXPERIENCE"
                android:textAllCaps="true"
                android:textColor="#404040"
                android:textSize="12sp"
                android:letterSpacing="0.1"/>

            <!-- Original Experience Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_dark_input"
                android:padding="16dp">

                <TextView
                    android:id="@+id/text_label_original"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_bold"
                    android:text="Your current version"
                    android:textColor="#606060"
                    android:textSize="10sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/poppins_regular"
                    android:text="Responsible for leading the design team and creating user interfaces for several mobile applications."
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    app:layout_constraintTop_toBottomOf="@id/text_label_original" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:layout_marginVertical="16dp"
                android:src="@android:drawable/arrow_down_float"
                app:tint="@color/metricValue" />

            <!-- AI Suggested Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/neon_glow_card"
                android:padding="20dp">

                <TextView
                    android:id="@+id/text_label_ai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_bold"
                    android:text="AI Optimized version"
                    android:textColor="@color/metricValue"
                    android:textSize="10sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="Spearheaded a cross-functional design team of 5, delivering end-to-end UX/UI solutions for 3+ high-traffic mobile applications, resulting in a 25% increase in user engagement."
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    app:layout_constraintTop_toBottomOf="@id/text_label_ai" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="#1AFFFFFF"
                        android:fontFamily="@font/poppins_bold"
                        android:text="Copy"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:cornerRadius="12dp"
                        app:strokeColor="#33FFFFFF"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1.5"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@color/metricValue"
                        android:fontFamily="@font/poppins_bold"
                        android:text="Apply Change"
                        android:textAllCaps="false"
                        android:textColor="#050510"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/poppins_bold"
                android:text="KEY IMPROVEMENTS"
                android:textAllCaps="true"
                android:textColor="#404040"
                android:textSize="12sp"
                android:letterSpacing="0.1"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/card_dark_input"
                    android:fontFamily="@font/poppins_regular"
                    android:padding="16dp"
                    android:text="• Added action verbs (Spearheaded, Delivering)"
                    android:textColor="#B0B0B0"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/card_dark_input"
                    android:fontFamily="@font/poppins_regular"
                    android:padding="16dp"
                    android:text="• Included quantifiable metrics (25% increase)"
                    android:textColor="#B0B0B0"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/card_dark_input"
                    android:fontFamily="@font/poppins_regular"
                    android:padding="16dp"
                    android:text="• Integrated keyword: UX/UI Solutions"
                    android:textColor="#B0B0B0"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
