<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/welcomeFragment">

    <fragment
        android:id="@+id/welcomeFragment"
        android:name="com.example.ats_score_checker.fragments.WelcomeFragment"
        android:label="Welcome"
        tools:layout="@layout/fragment_welcome">
        <action android:id="@+id/action_welcomeFragment_to_inputFragment" app:destination="@id/inputFragment" />
    </fragment>

    <fragment
        android:id="@+id/inputFragment"
        android:name="com.example.ats_score_checker.fragments.InputFragment"
        android:label="Input"
        tools:layout="@layout/fragment_input">
        <action android:id="@+id/action_inputFragment_to_dashboardFragment" app:destination="@id/dashboardFragment" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.ats_score_checker.fragments.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action android:id="@+id/action_dashboard_to_input" app:destination="@id/inputFragment" />
        <action android:id="@+id/action_dashboardFragment_to_improvementTipsFragment"
            app:destination="@id/improvementTipsFragment" />
        <action android:id="@+id/action_dashboardFragment_to_missingSkillsFragment"
            app:destination="@id/missingSkillsFragment" />
    </fragment>

    <fragment
        android:id="@+id/improvementTipsFragment"
        android:name="com.example.ats_score_checker.fragments.ImprovementTipsFragment"
        android:label="Improvement Tips"
        tools:layout="@layout/fragment_improvement_tips" />

    <fragment
        android:id="@+id/missingSkillsFragment"
        android:name="com.example.ats_score_checker.fragments.MissingSkillsFragment"
        android:label="Missing Skills"
        tools:layout="@layout/fragment_missing_skills" />

    <fragment
        android:id="@+id/mockInterviewFragment"
        android:name="com.example.ats_score_checker.fragments.MockInterviewFragment"
        android:label="Mock Interview"
        tools:layout="@layout/fragment_mock_interview" />

    <fragment
        android:id="@+id/keywordDetailsFragment"
        android:name="com.example.ats_score_checker.fragments.KeywordDetailsFragment"
        android:label="Keyword Details"
        tools:layout="@layout/fragment_keyword_details" />

    <fragment
        android:id="@+id/resumeEditorFragment"
        android:name="com.example.ats_score_checker.fragments.ResumeEditorFragment"
        android:label="Resume Editor"
        tools:layout="@layout/fragment_resume_editor" />

    <fragment
        android:id="@+id/rewriteSuggestionsFragment"
        android:name="com.example.ats_score_checker.fragments.RewriteSuggestionsFragment"
        android:label="Rewrite Suggestions"
        tools:layout="@layout/fragment_rewrite_suggestions" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.ats_score_checker.fragments.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />

</navigation>
