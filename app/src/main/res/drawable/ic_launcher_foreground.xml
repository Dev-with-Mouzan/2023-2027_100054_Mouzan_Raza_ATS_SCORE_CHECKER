<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Rounded background for the logo itself within the icon -->
    <item
        android:width="80dp"
        android:height="80dp"
        android:gravity="center">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- The logo centered on top of the rounded background -->
    <item
        android:drawable="@drawable/college_logo"
        android:gravity="center"
        android:width="64dp"
        android:height="64dp" />
</layer-list>